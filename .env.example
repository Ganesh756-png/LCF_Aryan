# Supabase PostgreSQL Database Connection Configuration
# You can find these details in Supabase Dashboard > Project Settings > Database

# Complete JDBC Connection URL (Recommended for overriding everything, especially for adding SSL parameters)
# E.g. DB_URL=jdbc:postgresql://db.xxxx.supabase.co:5432/postgres?sslmode=require
DB_URL=jdbc:postgresql://localhost:5432/local_service_finder

# Individual connection parameters (Used if DB_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=local_service_finder
DB_USER=postgres
DB_PASSWORD=postgres

# Database Initialization Mode
# Set to 'always' on the first run to create tables and seed mock data.
# Set to 'never' once the tables are created so you don't lose data on subsequent restarts.
SQL_INIT_MODE=always

# Supabase Auth JWT Secret (used to decode and verify JWT signatures)
# Retrieve from Supabase Dashboard > Project Settings > API > JWT Secret
# Set to a real secret key to enable real JWT signature verification instead of local mock bypass.
JWT_SECRET=supabase_jwt_secret_placeholder_must_be_at_least_256_bits_long_abcdefghijklmnopqrstuvwxyz123456

# SMTP Server Configurations for Email Status Alerts (e.g. Mailtrap or Sendgrid)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=placeholder_user
MAIL_PASSWORD=placeholder_password
